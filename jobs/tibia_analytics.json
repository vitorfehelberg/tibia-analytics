{
  "name": "tibia_analytics",
  "email_notifications": {
    "no_alert_for_skipped_runs": true,
    "on_failure": ["<REPLACE_WITH_YOUR_EMAIL>"]
  },
  "webhook_notifications": {},
  "notification_settings": {
    "no_alert_for_skipped_runs": true,
    "no_alert_for_canceled_runs": true
  },
  "timeout_seconds": 7200,
  "max_concurrent_runs": 1,
  "performance_target": "PERFORMANCE_OPTIMIZED",
  "tasks": [
    {
      "task_key": "schema_bootstrap",
      "run_job_task": {
        "job_id": "<REPLACE_WITH_SCHEMA_BOOTSTRAP_JOB_ID>"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    },
    {
      "task_key": "data_ingestion",
      "depends_on": [
        {
          "task_key": "schema_bootstrap"
        }
      ],
      "run_job_task": {
        "job_id": "<REPLACE_WITH_DATA_INGESTION_JOB_ID>"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    }
  ],
  "schedule": {
    "quartz_cron_expression": "22 30 10 * * ?",
    "timezone_id": "Europe/Berlin",
    "pause_status": "UNPAUSED"
  },
  "queue": {
    "enabled": true
  },
  "format": "MULTI_TASK"
}