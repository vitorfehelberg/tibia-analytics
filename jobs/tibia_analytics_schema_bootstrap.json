{
  "name": "tibia_analytics_schema_bootstrap",
  "description": "Bootstrap all schemas, utility objects, and analytical tables required by the Tibia Analytics platform.",
  "email_notifications": {
    "no_alert_for_skipped_runs": true
  },
  "notification_settings": {
    "no_alert_for_canceled_runs": true,
    "no_alert_for_skipped_runs": true
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "max_concurrent_runs": 1,
  "performance_target": "PERFORMANCE_OPTIMIZED",
  "tasks": [
    {
      "task_key": "config_bootstrap",
      "notebook_task": {
        "notebook_path": "notebooks/config/bootstrap",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "bronze_characters_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/bronze/characters/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "bronze_highscores_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/bronze/highscores/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "bronze_worlds_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/bronze/worlds/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "config_api_client",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/config/api_client",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "gold_characters_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/gold/characters/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "gold_cohort_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/gold/cohort/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "gold_worlds_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/gold/worlds/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "silver_characters_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/silver/characters/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "silver_worlds_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/silver/worlds/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "utils_create_table",
      "depends_on": [{"task_key": "config_bootstrap"}],
      "notebook_task": {
        "notebook_path": "notebooks/utils/create_table",
        "source": "GIT"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "utils_calendar_seeded_check",
      "depends_on": [{"task_key": "utils_create_table"}],
      "sql_task": {
        "query": {
          "query_id": "<REPLACE_WITH_QUERY_ID>"
        },
        "warehouse_id": "<REPLACE_WITH_WAREHOUSE_ID>"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "is_utils_calendar_seeded",
      "depends_on": [{"task_key": "utils_calendar_seeded_check"}],
      "condition_task": {
        "left": "{{tasks.utils_calendar_seeded_check.output.first_row.calendar_seeded}}",
        "op": "EQUAL_TO",
        "right": "TRUE"
      },
      "timeout_seconds": 0
    },
    {
      "task_key": "utils_calendar_seed",
      "depends_on": [
        {
          "task_key": "is_utils_calendar_seeded",
          "outcome": "false"
        }
      ],
      "notebook_task": {
        "notebook_path": "notebooks/utils/calendar_seed",
        "source": "GIT"
      },
      "timeout_seconds": 0
    }
  ],
  "queue": {
    "enabled": true
  },
  "format": "MULTI_TASK"
}